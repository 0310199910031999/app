# Copia este archivo como ".env" y rellena los valores reales
# NUNCA subas el .env al repositorio

# Base de datos
DATABASE_URL="postgresql+psycopg2://usuario:contraseña@host:5432/nombre_bd"

# Configuración SMTP
SMTP_HOST="smtp.office365.com"
SMTP_PORT=587
SMTP_USER="correo@tudominio.com"
SMTP_PASSWORD="tu_contraseña_smtp"
SMTP_FROM_EMAIL="correo@tudominio.com"
SMTP_FROM_NAME="Nombre Empresa"

# URL base para enlaces en emails
BASE_URL="http://tudominio.com/dashboard"
EXPORT_BASE_URL="http://api.tudominio.com"

# Redis / colas
REDIS_URL="redis://localhost:6379/0"
EXPORT_QUEUE_DRIVER="redis"
NOTIFICATION_QUEUE_DRIVER="thread"
NOTIFICATION_QUEUE_NAME="notifications"

# Firebase Cloud Messaging
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID="tu-proyecto-firebase"
FIREBASE_CREDENTIALS_FILE="C:/ruta/a/firebase-service-account.json"
# Alternativa a FIREBASE_CREDENTIALS_FILE: pega aquí el JSON completo escapado en una sola línea.
FIREBASE_CREDENTIALS_JSON=
FIREBASE_ANDROID_CHANNEL_ID="documents"
FIREBASE_NOTIFICATION_SOUND="default"

# Para pruebas locales puedes usar la URL del API local.
# EXPORT_BASE_URL="http://127.0.0.1:8000"
